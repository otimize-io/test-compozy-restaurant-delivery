{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "RabbitMq": "rabbitmq://localhost"
  },
  "ReverseProxy": {
    "Routes": {
      "search": {
        "ClusterId": "search",
        "Match": {
          "Path": "/api/restaurants"
        }
      },
      "catalog-detail": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/restaurants/{id}"
        }
      },
      "catalog-menu": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/restaurants/{id}/menu"
        }
      },
      "orders-place": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/orders",
          "Methods": [ "POST" ]
        }
      },
      "orders-status": {
        "ClusterId": "tracking",
        "Match": {
          "Path": "/api/orders/{id}/status"
        }
      },
      "orders-accept": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/orders/{id}/accept"
        }
      },
      "orders-ready": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/orders/{id}/ready"
        }
      },
      "orders-pickup": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/orders/{id}/pickup"
        }
      },
      "orders-deliver": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/orders/{id}/deliver"
        }
      },
      "orders-get": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/orders/{id}",
          "Methods": [ "GET" ]
        }
      },
      "restaurant-orders": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/restaurant/orders"
        }
      },
      "driver-assignments": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/driver/assignments"
        }
      },
      "payments-callback": {
        "ClusterId": "payment",
        "Match": {
          "Path": "/api/payments/callback"
        }
      }
    },
    "Clusters": {
      "search": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5005/"
          }
        }
      },
      "catalog": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "order": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5006/"
          }
        }
      },
      "payment": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5007/"
          }
        }
      },
      "tracking": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5012/"
          }
        }
      }
    }
  }
}
