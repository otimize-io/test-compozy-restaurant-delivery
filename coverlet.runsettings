<?xml version="1.0" encoding="utf-8"?>
<!--
  Coverage settings, applied via the "settings coverlet.runsettings" test option.
  Program.cs files are application composition roots (host wiring + DI registration) with no
  business logic to meaningfully unit-test, so they are excluded from the coverage denominator.
-->
<RunSettings>
  <RunConfiguration>
    <!-- Run one test assembly at a time. The in-memory MassTransit harness has a teardown race that
         only surfaces under heavy cross-assembly CPU contention; serializing assemblies makes the
         harness lifecycle deterministic. Test projects remain individually fast. -->
    <MaxCpuCount>1</MaxCpuCount>
  </RunConfiguration>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <ExcludeByFile>**/Program.cs</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
